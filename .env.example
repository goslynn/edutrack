# EduTrack — plantilla de variables. Copiar a `.env` y completar los secretos:
#
#   cp .env.example .env
#
# `.env` es OBLIGATORIO (el compose hace `env_file: ./.env` y exige los secretos
# con `${VAR:?}`). Versiona ESTE archivo (.env.example), nunca `.env`.

# ── Secretos (OBLIGATORIOS — sin default en el compose; reemplaza los valores) ───
DB_PASSWORD=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME

# ── Base de datos (instancia única compartida, schema-per-service) ──────────────
POSTGRES_IMAGE=postgres:16-alpine
DB_USER=postgres
DB_NAME=edutrack_local
DB_PORT=5432
# Hostname con el que los CONTENEDORES alcanzan la DB (alias de red de `database`).
DB_HOST=database
DB_CONTAINER_NAME=postgres
DB_VOLUME=edutrack_pgdata

# ── Red ─────────────────────────────────────────────────────────────────────────
EDUTRACK_NETWORK=edutrack

# ── Microservicios (Quarkus) ────────────────────────────────────────────────────
QUARKUS_PROFILE=dev
EDUTRACK_DISCOVERY_PATTERN={service}:8080
EDUTRACK_DISCOVERY_SCHEME=http

# ── Llaves RS256 ─────────────────────────────────────────────────────────────────
# Directorio host con privateKey.pem + publicKey.pem (montado read-only en /certs).
#   Genera las llaves y colócalas ahí; NO se versionan.
EDUTRACK_CERTS_DIR=./.certs

# ── Puertos publicados al host (override opcional) ──────────────────────────────
# GATEWAY_PORT=8080
# AUTH_PORT=8081
# ATTENDANCE_PORT=8082
# STUDENT_PORT=8083
# NOTIFICATION_PORT=8087
# CONTENT_PORT=8088
# REPORT_PORT=8089
# FRONT_PORT=5173

# ── Content Service (arbol + archivos) ───────────────────────────────────────────
# Almacenamiento de archivos: Strategy FileSystem v1 sobre un volumen persistente.
# El path DENTRO del contenedor (montado desde el volumen `content_files`).
# CONTENT_STORAGE_DIR=/data/content
# CONTENT_VOLUME=edutrack_content_files
# Secreto HMAC que firma los enlaces de descarga temporales (override en prod).
# CONTENT_DOWNLOAD_SECRET=CHANGE_ME

# ── Notification Service (correo) ────────────────────────────────────────────────
# Por defecto el mailer va en modo MOCK en local (no envía correo real, lo captura
#   en memoria). Para envío real vía Brevo SMTP: MAIL_MOCK=false + creds del proveedor.
# MAIL_MOCK=false
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_FROM=no-reply@edutrack.cl
# MAIL_USER=CHANGE_ME
# MAIL_PASSWORD=CHANGE_ME

# ── Report Service (definiciones + generacion JSON/CSV/PDF) ─────────────────────
# Credenciales read-only cross-schema (ADR-001): datasource `readonly` para leer los
#   schemas ajenos al consolidar reportes. Si se omiten, caen al DB_USER/DB_PASSWORD
#   compartidos (suficiente en local). En prod: rol con SELECT sobre los demas schemas.
# DB_RO_USER=report_ro
# DB_RO_PASSWORD=CHANGE_ME

# ── Build contexts (el nombre del directorio NO es contrato; default = layout actual)
# AUTH_CONTEXT=./auth
# ATTENDANCE_CONTEXT=./attendance
# STUDENT_CONTEXT=./student
# NOTIFICATION_CONTEXT=./notification
# CONTENT_CONTEXT=./content
# REPORT_CONTEXT=./report
# GATEWAY_CONTEXT=./infra/gateway
# FRONT_CONTEXT=./front

# ── Frontend ────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
