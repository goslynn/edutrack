# EduTrack — plantilla de variables. Copiar a `.env` y completar los secretos:
#
#   cp .env.example .env
#
# `.env` es OBLIGATORIO (el compose hace `env_file: ./.env` y exige los secretos
# con `${VAR:?}`). Versiona ESTE archivo (.env.example), nunca `.env`.

# ── Secretos (OBLIGATORIOS — sin default en el compose; reemplaza los valores) ───
DB_PASSWORD=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME

# ── Base de datos (instancia única compartida, schema-per-service) ──────────────
POSTGRES_IMAGE=postgres:16-alpine
DB_USER=postgres
DB_NAME=edutrack_local
DB_PORT=5432
# Hostname con el que los CONTENEDORES alcanzan la DB (alias de red de `database`).
DB_HOST=database
DB_CONTAINER_NAME=postgres
DB_VOLUME=edutrack_pgdata

# ── Red ─────────────────────────────────────────────────────────────────────────
EDUTRACK_NETWORK=edutrack

# ── Microservicios (Quarkus) ────────────────────────────────────────────────────
QUARKUS_PROFILE=dev
EDUTRACK_DISCOVERY_PATTERN={service}:8080
EDUTRACK_DISCOVERY_SCHEME=http

# ── Llaves RS256 ─────────────────────────────────────────────────────────────────
# Directorio host con privateKey.pem + publicKey.pem (montado read-only en /certs).
#   Genera las llaves y colócalas ahí; NO se versionan.
EDUTRACK_CERTS_DIR=./.certs

# ── Puertos publicados al host (override opcional) ──────────────────────────────
# GATEWAY_PORT=8080
# AUTH_PORT=8081
# ATTENDANCE_PORT=8082
# STUDENT_PORT=8083
# FRONT_PORT=5173

# ── Build contexts (el nombre del directorio NO es contrato; default = layout actual)
# AUTH_CONTEXT=./auth
# ATTENDANCE_CONTEXT=./attendance
# STUDENT_CONTEXT=./student
# GATEWAY_CONTEXT=./infra/gateway
# FRONT_CONTEXT=./front

# ── Frontend ────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
